# =============================================
#  4llboTracker Discord Bot - Environment File
# =============================================
# Salin file ini menjadi ".env" dan isi dengan data kamu

# Token bot Discord (dari https://discord.com/developers/applications)
DISCORD_TOKEN=masukkan_token_bot_discord_kamu_disini

# ID Server Discord kamu (aktifkan Developer Mode -> klik kanan server -> Copy ID)
GUILD_ID=masukkan_guild_id_server_discord_kamu

# ID Channel untuk notifikasi otomatis server FiveM (opsional)
# Jika diisi, bot akan mengirim update status server secara berkala
MONITOR_CHANNEL_ID=masukkan_channel_id_untuk_notifikasi

# Interval monitoring dalam menit (default: 5 menit)
MONITOR_INTERVAL_MINUTES=5

# Konfigurasi Database MySQL
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=db_4llbotracker
